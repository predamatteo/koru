<?xml version="1.0" encoding="utf-8"?>
<!--
    Regole di estrazione dati: escludiamo TUTTO da cloud backup e device
    transfer. Koru contiene preferenze locali, DB con dati di utilizzo e
    file di stato del blocking engine che non devono propagarsi tra
    dispositivi: il ripristino su un device diverso porterebbe a uno
    stato incoerente (es. timestamp di sessioni Pomodoro, pacchetti
    bloccati che non esistono sul device target, identificativi di
    profili etc.). Meglio partire puliti.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
